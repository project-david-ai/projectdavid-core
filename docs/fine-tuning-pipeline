# pseudo code — auto-register after training completes
async def register_from_job(job: TrainingJob):
    model_id = generate_id("ftm_")
    model = FineTunedModel(
        id=model_id,
        user_id=job.user_id,
        training_job_id=job.id,
        name=f"{job.base_model.split('/')[-1]}-ft-{job.id[:8]}",
        base_model=job.base_model,
        storage_path=job.output_path,
        status=StatusEnum.processing,
        is_active=False,
    )
    db.add(model); db.commit()

    # Optionally push to HF Hub if HF_TOKEN is set
    if os.getenv("HF_TOKEN"):
        asyncio.create_task(_push_to_hub(model))
    else:
        model.status = StatusEnum.active
        db.commit()

    return model


# pseudo code — POST /v1/fine-tuned-models/{id}/activate
async def activate_model(model_id: str, user: User):
    model = get_model_or_404(model_id, user.id)

    # Deactivate any currently active model
    db.query(FineTunedModel).filter(
        FineTunedModel.user_id == user.id,
        FineTunedModel.is_active == True,
    ).update({"is_active": False})

    # Set new active model
    vllm_model_id = model.hf_repo or model.storage_path
    model.is_active = True
    model.vllm_model_id = vllm_model_id
    db.commit()

    # Write to .env so vLLM picks it up on next restart
    set_key(".env", "VLLM_MODEL", vllm_model_id)

    return {
        "activated": model_id,
        "vllm_model_id": vllm_model_id,
        "next_step": "pdavid --mode up --vllm --pull to serve the new model",
    }


# pseudo code — POST /v1/fine-tuned-models/{id}/push
async def push_to_hub(model_id: str, payload: HubPushPayload, user: User):
    model = get_model_or_404(model_id, user.id)
    model.status = StatusEnum.processing
    db.commit()
    asyncio.create_task(_push_to_hub(model, repo_id=payload.repo_id))
    return {"status": "pushing", "model_id": model_id}


async def _push_to_hub(model: FineTunedModel, repo_id: str = None):
    try:
        from huggingface_hub import HfApi
        api = HfApi(token=os.getenv("HF_TOKEN"))
        target_repo = repo_id or f"projectdavid/{model.name}"
        api.upload_folder(
            folder_path=model.storage_path,
            repo_id=target_repo,
            repo_type="model",
        )
        model.hf_repo = target_repo
        model.status = StatusEnum.active
    except Exception as e:
        model.status = StatusEnum.failed
        model.config = {"push_error": str(e)}
    finally:
        db.commit()


